# --- Dominio público ---
N8N_DOMAIN=n8n.tudominio.com

# --- Clave de cifrado de credenciales ---
# Generar con: openssl rand -hex 32
# IMPORTANTE: una vez establecida, NO la cambies o perderás acceso a las credenciales guardadas
N8N_ENCRYPTION_KEY=reemplaza_por_la_salida_de_openssl

#Variables para la DB
N8N_DB_USER=n8nuser
N8N_DB_PASSWORD=<la_pass_que_generaste>
N8N_DB_NAME=n8n_app