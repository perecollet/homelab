{
    email your-email@example.com
    acme_dns cloudflare {env.CLOUDFLARE_API_TOKEN}
}

# --- Internal HTTP listener for Cloudflare Tunnel (no redirect) ---
:2080 {
    @portfolio host perecollet.dev
    handle @portfolio {
        reverse_proxy portfolio_site:80
    }

    @photos host photos.perecollet.dev
    handle @photos {
        reverse_proxy immich_server:2283
    }

    @files host files.perecollet.dev
    handle @files {
        reverse_proxy filebrowser:80
    }

    @ads host ads.perecollet.dev
    handle @ads {
        reverse_proxy adguard:80
    }
}

# --- HTTPS (LAN access) ---

perecollet.dev {
    reverse_proxy portfolio_site:80
}

photos.perecollet.dev {
    reverse_proxy immich_server:2283
}

files.perecollet.dev {
    reverse_proxy filebrowser:80
}

ads.perecollet.dev {
    reverse_proxy adguard:80
}
